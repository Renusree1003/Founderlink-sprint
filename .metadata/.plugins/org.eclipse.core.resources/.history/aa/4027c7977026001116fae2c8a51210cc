spring.cloud.gateway.routes[11].uri=lb://INVESTMENT-SERVICE
spring.cloud.gateway.routes[11].predicates[0]=Path=/investment-service/v3/api-docs/**
spring.cloud.gateway.routes[11].filters[0]=RewritePath=/investment-service/v3/api-docs(?<segment>/?.*), /v3/api-docs${segment}