server.port=8080
spring.application.name=api-gateway

# =========================
# EUREKA
# =========================
eureka.client.service-url.defaultZone=http://localhost:8761/eureka

# =========================
# DISCOVERY (AUTO ROUTING)
# =========================
spring.cloud.gateway.discovery.locator.enabled=true
spring.cloud.gateway.discovery.locator.lower-case-service-id=true

# =========================
# LOGGING
# =========================
logging.level.org.springframework.cloud.gateway=DEBUG


# =========================================================
# AUTH SERVICE
# =========================================================
spring.cloud.gateway.routes[0].id=auth-service
spring.cloud.gateway.routes[0].uri=lb://AUTH-SERVICE
spring.cloud.gateway.routes[0].predicates[0]=Path=/auth/**

# Swagger AUTH (FIXED \uD83D\uDD25)
spring.cloud.gateway.routes[1].id=auth-swagger-ui
spring.cloud.gateway.routes[1].uri=lb://AUTH-SERVICE
spring.cloud.gateway.routes[1].predicates[0]=Path=/auth-service/swagger-ui/**

spring.cloud.gateway.routes[2].id=auth-api-docs
spring.cloud.gateway.routes[2].uri=lb://AUTH-SERVICE
spring.cloud.gateway.routes[2].predicates[0]=Path=/auth-service/v3/api-docs/**
spring.cloud.gateway.routes[2].filters[0]=RewritePath=/auth-service/v3/api-docs(?<segment>/?.*), /v3/api-docs${segment}


# =========================================================
# USER SERVICE
# =========================================================
spring.cloud.gateway.routes[3].id=user-service
spring.cloud.gateway.routes[3].uri=lb://USER-SERVICE
spring.cloud.gateway.routes[3].predicates[0]=Path=/users/**

# Swagger USER
spring.cloud.gateway.routes[4].id=user-swagger-ui
spring.cloud.gateway.routes[4].uri=lb://USER-SERVICE
spring.cloud.gateway.routes[4].predicates[0]=Path=/user-service/swagger-ui/**

spring.cloud.gateway.routes[5].id=user-api-docs
spring.cloud.gateway.routes[5].uri=lb://USER-SERVICE
spring.cloud.gateway.routes[5].predicates[0]=Path=/user-service/v3/api-docs/**
spring.cloud.gateway.routes[5].filters[0]=RewritePath=/user-service/v3/api-docs(?<segment>/?.*), /v3/api-docs${segment}


# =========================================================
# STARTUP SERVICE
# =========================================================
spring.cloud.gateway.routes[6].id=startup-service
spring.cloud.gateway.routes[6].uri=lb://STARTUP-SERVICE
spring.cloud.gateway.routes[6].predicates[0]=Path=/startups/**

# Swagger STARTUP
spring.cloud.gateway.routes[7].id=startup-swagger-ui
spring.cloud.gateway.routes[7].uri=lb://STARTUP-SERVICE
spring.cloud.gateway.routes[7].predicates[0]=Path=/startup-service/swagger-ui/**

spring.cloud.gateway.routes[8].id=startup-api-docs
spring.cloud.gateway.routes[8].uri=lb://STARTUP-SERVICE
spring.cloud.gateway.routes[8].predicates[0]=Path=/startup-service/v3/api-docs/**
spring.cloud.gateway.routes[8].filters[0]=RewritePath=/startup-service/v3/api-docs(?<segment>/?.*), /v3/api-docs${segment}




# Enable actuator endpoints
management.endpoints.web.exposure.include=*

# Optional (for better info)
management.endpoint.health.show-details=always


# =========================================================
# INVESTMENT SERVICE
# =========================================================
spring.cloud.gateway.routes[9].id=investment-service
spring.cloud.gateway.routes[9].uri=lb://INVESTMENT-SERVICE
spring.cloud.gateway.routes[9].predicates[0]=Path=/investments/**

# Swagger INVESTMENT
spring.cloud.gateway.routes[10].id=investment-swagger-ui
spring.cloud.gateway.routes[10].uri=lb://INVESTMENT-SERVICE
spring.cloud.gateway.routes[10].predicates[0]=Path=/investment-service/swagger-ui/**

